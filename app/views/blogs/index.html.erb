<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>
  <% content_for :title, "Blogs" %>
  <div style="margin-bottom:2em"
  class="flex justify-between items-center">
    <h1 class="dark:text-slate-400 font-bold text-4xl">Blogs</h1>
    <% if user_signed_in? %>
    <%= link_to 'New blog', new_blog_path,
    class: "rounded-lg py-3 px-4 bg-blue-600
    text-white block font-medium" %>
    <% end %>
  </div>
  <div style="margin-bottom:1.6em">
  <%= form_with(url: blogs_path, method: :get,
  data: {turbo_frame: "blogs", turbo_action: "advance"}) do |form| %>
      <%= form.label :query, "Search by blog name:",
      class: "block mb-2" %>
      <div class="flex space-x-3">
        <%= form.text_field :query, class: "py-2 px-4 rounded border ring-0
        focus:ring-4 focus:ring-orange-100 focus:shadow-none
        focus:border-orange-500 dark:text-slate-800 focus:outline-none",
        data: {action: "input->search-form#search"} %>

        <%= form.submit 'Search', class: "px-4 py-2 font-medium
        bg-orange-400 text-neutal-900 rounded flex items-center
        cursor-pointer hover:bg-orange-600 focus:ring-4 ring-0
        text-gray-900 hover:text-gray-100 focus:ring-orange-100" %>
      </div>
  <% end %>
  </div>
  <% if @pagy.count > @pagy.limit %>
  <%# The a variable below is set to a lambda that generates the a tag %>
  <%# Usage: a_tag = a.(page_number, text, classes: nil, aria_label: nil) %>
  <% a = pagy_anchor(@pagy) %>
  <nav class="pagy nav" aria-label="Pages">
    <%# Previous page link %>
    <% if @pagy.prev %>
      <%= a.(@pagy.prev, '&lt;', aria_label: 'Previous') %>
    <% else %>
      <a role="link" aria-disabled="true"
      aria-label="Previous">&lt;</a>
    <% end %>
    <%# Page links (series example: [1, :gap, 7, 8, "9", 10, 11, :gap, 36]) %>
    <% @pagy.series.each do |item| %>
      <% if item.is_a?(Integer) %>
        <%= a.(item) %>
      <% elsif item.is_a?(String) %>
        <a role="link" aria-disabled="true"
        aria-current="page" class="current">
        <%= item %></a>
      <% elsif item == :gap %>
        <a role="link" aria-disabled="true"
        class="gap">&hellip;</a>
      <% end %>
    <% end %>
    <%# Next page link %>
    <% if @pagy.next %>
      <%= a.(@pagy.next, '&gt;', aria_label: 'Next') %>
    <% else %>
      <a role="link" aria-disabled="true"
      aria-label="Next">&lt;</a>
    <% end %>
  </nav>
    <div class="mt-10">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
  <div style="margin-top:1em; margin-bottom:2em"
  id="blogs" class="min-w-full">
    <table>
      <thead>
        <tr>
          <th style="width:10px; heigh:auto"></th>
          <th class="margin:10px; padding-left:10px;
          padding-right:10px;"></th>
          <th style="width:10px; heigh:auto"></th>
          <th colspan="3"></th>
        </tr>
      </thead>

      <tbody>
        <% @blogs.order('created_at').each do |blog| %>
          <tr>
            <td style="padding-top:0.5em; padding-right:0;
            padding-bottom:0.5em; padding-left:0">
              <h5 style="margin-right:1em">
                <strong class="dark:text-slate-300
                block font-medium 1mb-1">
                <a href="/blogs/<%= blog.id %>",
                class="nav-link"><%= blog.name %></a>
                </strong>
              </h5>
            </td>
            <td class="vertical-menu">
              <ul style="margin-top:1.2em; margin-bottom:1.2em;
              margin-right:1.2e"
              class="container z-10 1flex 1flex-wrap 1vertical-menu
              1items-center 1justify-center gap-6 ">
                <% blog.novines.order('created_at DESC').each do |novine| %>
                <li style="margin-top:0.6em; margin-bottom:0.6em"
                class="z-10 flex flex-wrap vertical-menu">
                  <a href="/novines/<%= novine.id %>",
                    class="nav-link">
                    <%= truncate(strip_tags(novine.title.to_s),
                    length:50) %></a>
                 </li>
                 <% end %>
              </ul>
            </td>
            <td>
              <%= link_to 'Show', blog,
              style:"margin-left:1em; margin-right:1em;",
              class:"dark:text-slate-400" %></td>
            <% if user_signed_in? %>
            <td style="width:7px; heigh:auto">
              <%= link_to 'Edit', edit_blog_path(blog),
                class:"dark:text-slate-400" %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @pagy.count > @pagy.limit %>
    <div class="mt-10">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
  <br />
  <% if user_signed_in? %>
  <div class="flex justify-between items-center">
    <%= link_to 'New blog', new_blog_path,
    class: "rounded-lg py-3 px-4 bg-blue-600
    text-white block font-medium" %>
  </div>
  <% end %>
  <br />
</div>
