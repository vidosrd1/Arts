<div id="<%= dom_id lost %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= lost.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= lost.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Thumbnail url:</strong>
    <%= lost.thumbnail_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Video url:</strong>
    <%= lost.video_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Pro:</strong>
    <%= lost.pro? ? "Yes" : "No" %>
  </div>
</div>
